&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;&lt;span class=&#34;se&#34;&gt;&lt;/span&gt;	&lt;span class=&#34;k&#34;&gt;done&lt;/span&gt; &amp;gt;&amp;gt; &lt;span class=&#34;k&#34;&gt;$(&lt;/span&gt;VSRC_PATH&lt;span class=&#34;k&#34;&gt;)&lt;/span&gt;/filelist.f
